  "components": {
    "schemas": {
      "BookingDto": {
        "required": [
          "checkIn",
          "checkOut",
          "paymentStatus",
          "roomId",
          "totalAmount",
          "userId"
        ],
        "type": "object",
        "properties": {
          "userId": {
            "type": "integer",
            "format": "int32"
          },
          "roomId": {
            "type": "integer",
            "format": "int32"
          },
          "checkIn": {
            "type": "string",
            "format": "date"
          },
          "checkOut": {
            "type": "string",
            "format": "date"
          },
          "paymentStatus": {
            "minLength": 1,
            "type": "string"
          },
          "totalAmount": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "HotelDto": {
        "type": "object",
        "properties": {
          "hotelId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "location": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "price": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "LoginDto": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "PaymentDto": {
        "required": [
          "amount",
          "bookingId",
          "paymentDate"
        ],
        "type": "object",
        "properties": {
          "bookingId": {
            "type": "integer",
            "format": "int32"
          },
          "amount": {
            "maximum": 100000,
            "minimum": 0,
            "type": "number",
            "format": "double"
          },
          "paymentDate": {
            "type": "string",
            "format": "date"
          },
          "status": {
            "type": "string",
            "default": "Paid",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RatingDto": {
        "required": [
          "hotelId",
          "rating1",
          "userId"
        ],
        "type": "object",
        "properties": {
          "hotelId": {
            "type": "integer",
            "format": "int32"
          },
          "userId": {
            "type": "integer",
            "format": "int32"
          },
          "rating1": {
            "maximum": 5,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "review": {
            "minLength": 5,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RoomDto": {
        "required": [
          "hotelId",
          "price",
          "type"
        ],
        "type": "object",
        "properties": {
          "hotelId": {
            "type": "integer",
            "format": "int32"
          },
          "type": {
            "minLength": 1,
            "type": "string"
          },
          "price": {
            "maximum": 100000,
            "minimum": 0,
            "type": "number",
            "format": "double"
          },
          "availability": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "RoomUpdateDto": {
        "required": [
          "availability",
          "price",
          "type"
        ],
        "type": "object",
        "properties": {
          "type": {
            "minLength": 1,
            "type": "string"
          },
          "price": {
            "type": "number",
            "format": "double"
          },
          "availability": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "UserDto": {
        "required": [
          "email",
          "name",
          "password"
        ],
        "type": "object",
        "properties": {
          "name": {
            "minLength": 3,
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 5,
            "type": "string"
          },
          "role": {
            "type": "string",
            "default": "User",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}